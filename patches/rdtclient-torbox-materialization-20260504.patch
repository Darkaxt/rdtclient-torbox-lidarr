+    public static String? FinalizeCompletedDownload(String filePath, TimeSpan? waitTimeout = null, TimeSpan? retryDelay = null)
+    {
+        var timeout = waitTimeout ?? TimeSpan.FromSeconds(10);
+        var delay = retryDelay ?? TimeSpan.FromMilliseconds(250);
+        var tempPath = $"{filePath}.download";
+        var deadline = DateTimeOffset.UtcNow.Add(timeout);
+
+        while (true)
+        {
+            if (File.Exists(filePath))
+            {
+                return null;
+            }
+
+            if (File.Exists(tempPath))
+            {
+                try
+                {
+                    var directory = Path.GetDirectoryName(filePath);
+
+                    if (!String.IsNullOrWhiteSpace(directory) && !Directory.Exists(directory))
+                    {
+                        Directory.CreateDirectory(directory);
+                    }
+
+                    File.Move(tempPath, filePath);
+
+                    return null;
+                }
+                catch (Exception ex)
+                {
+                    if (File.Exists(filePath))
+                    {
+                        return null;
+                    }
+
+                    return $"Download completed but failed to finalize {tempPath}: {ex.Message}";
+                }
+            }
+
+            if (timeout <= TimeSpan.Zero || DateTimeOffset.UtcNow >= deadline)
+            {
+                return $"Download completed but neither final file nor temporary file exists: {filePath}";
+            }
+
+            Thread.Sleep(delay);
+        }
+    }
+
