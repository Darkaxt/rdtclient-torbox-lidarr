+using RdtClient.Service.Services.Downloaders;
+
+namespace RdtClient.Service.Test.Services.Downloaders;
+
+public class BezzadDownloaderTest
+{
+    [Fact]
+    public void FinalizeCompletedDownload_ReturnsSuccess_WhenFinalFileExists()
+    {
+        var dir = CreateTempDirectory();
+        var filePath = Path.Combine(dir, "book.epub");
+
+        try
+        {
+            File.WriteAllText(filePath, "complete");
+
+            var error = BezzadDownloader.FinalizeCompletedDownload(filePath, TimeSpan.Zero, TimeSpan.Zero);
+
+            Assert.Null(error);
+            Assert.True(File.Exists(filePath));
+        }
+        finally
+        {
+            Directory.Delete(dir, true);
+        }
+    }
+
+    [Fact]
+    public void FinalizeCompletedDownload_PromotesTemporaryFile_WhenOnlyDownloadFileExists()
+    {
+        var dir = CreateTempDirectory();
+        var filePath = Path.Combine(dir, "book.epub");
+        var tempPath = $"{filePath}.download";
+
+        try
+        {
+            File.WriteAllText(tempPath, "complete");
+
+            var error = BezzadDownloader.FinalizeCompletedDownload(filePath, TimeSpan.Zero, TimeSpan.Zero);
+
+            Assert.Null(error);
+            Assert.True(File.Exists(filePath));
+            Assert.False(File.Exists(tempPath));
+            Assert.Equal("complete", File.ReadAllText(filePath));
+        }
+        finally
+        {
+            Directory.Delete(dir, true);
+        }
+    }
+
+    [Fact]
+    public void FinalizeCompletedDownload_ReturnsError_WhenNoOutputFileExists()
+    {
+        var dir = CreateTempDirectory();
+        var filePath = Path.Combine(dir, "book.epub");
+
+        try
+        {
+            var error = BezzadDownloader.FinalizeCompletedDownload(filePath, TimeSpan.Zero, TimeSpan.Zero);
+
+            Assert.NotNull(error);
+            Assert.Contains("neither final file nor temporary file exists", error);
+            Assert.False(File.Exists(filePath));
+        }
+        finally
+        {
+            Directory.Delete(dir, true);
+        }
+    }
+
+    private static String CreateTempDirectory()
+    {
+        var dir = Path.Combine(Path.GetTempPath(), $"rdt-bezzad-{Guid.NewGuid():N}");
+        Directory.CreateDirectory(dir);
+
+        return dir;
+    }
+}
